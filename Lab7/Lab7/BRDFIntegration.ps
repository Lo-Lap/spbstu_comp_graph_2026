static const float PI = 3.14159265359f;
struct VS_OUTPUT
{
	float4 Pos : SV_POSITION;
	float2 TexCoord : TEXCOORD0;
};

float RadicalInverse_VdC(uint bits)
{
	bits = (bits << 16u) | (bits >> 16u);
	bits = ((bits & 0x55555555u) << 1u) | ((bits & 0xAAAAAAAAu) >> 1u);
	bits = ((bits & 0x33333333u) << 2u) | ((bits & 0xCCCCCCCCu) >> 2u);
	bits = ((bits & 0x0F0F0F0Fu) << 4u) | ((bits & 0xF0F0F0F0u) >> 4u);
	bits = ((bits & 0x00FF00FFu) << 8u) | ((bits & 0xFF00FF00u) >> 8u);
	return float(bits) * 2.3283064365386963e-10;
}
float2 Hammersley(uint i, uint N)
{
	return float2((float)i / (float)N, RadicalInverse_VdC(i));
}

float3 ImportanceSampleGGX(float2 Xi, float3 N, float roughness)
{
	float a = roughness * roughness;
	float phi = 2.0f * PI * Xi.x;
	float cosTheta = sqrt((1.0f - Xi.y) / (1.0f + (a * a - 1.0f) * Xi.y));
	float sinTheta = sqrt(saturate(1.0f - cosTheta * cosTheta));
	float3 H;
	H.x = cos(phi) * sinTheta;
	H.y = sin(phi) * sinTheta;
	H.z = cosTheta;
	float3 up = abs(N.z) < 0.999f ? float3(0.0f, 0.0f, 1.0f) : float3(1.0f, 0.0f, 0.0f);
	float3 tangent = normalize(cross(up, N));
	float3 bitangent = cross(N, tangent);
	float3 sampleVec = tangent * H.x + bitangent * H.y + N * H.z;
	return normalize(sampleVec);
}

float GeometrySchlickGGX_IBL(float NdotV, float roughness)
{
	float a = roughness;
	float k = (a * a) * 0.5f;
	return NdotV / max(NdotV * (1.0f - k) + k, 1e-5f);
}

float GeometrySmith_IBL(float3 N, float3 V, float3 L, float roughness)
{
	float NdotV = saturate(dot(N, V));
	float NdotL = saturate(dot(N, L));
	float ggx1 = GeometrySchlickGGX_IBL(NdotV, roughness);
	float ggx2 = GeometrySchlickGGX_IBL(NdotL, roughness);
	return ggx1 * ggx2;
}

float2 IntegrateBRDF(float NdotV, float roughness)
{
	float3 V;
	V.x = sqrt(saturate(1.0f - NdotV * NdotV));
	V.y = 0.0f;
	V.z = NdotV;
	float3 N = float3(0.0f, 0.0f, 1.0f);
	float A = 0.0f;
	float B = 0.0f;
	const uint SAMPLE_COUNT = 1024u;
	for (uint i = 0u; i < SAMPLE_COUNT; ++i)
	{
	float2 Xi = Hammersley(i, SAMPLE_COUNT);
	float3 H = ImportanceSampleGGX(Xi, N, roughness);
	float3 L = normalize(2.0f * dot(V, H) * H - V);
	float NdotL = saturate(L.z);
	float NdotH = saturate(H.z);
	float VdotH = saturate(dot(V, H));
	if (NdotL > 0.0f)
	{
	float G = GeometrySmith_IBL(N, V, L, roughness);
	float G_Vis = (G * VdotH) / max(NdotH * NdotV, 1e-5f);
	float Fc = pow(1.0f - VdotH, 5.0f);
	A += (1.0f - Fc) * G_Vis;
	B += Fc * G_Vis;
	}
	}
	A /= SAMPLE_COUNT;
	B /= SAMPLE_COUNT;
	return float2(A, B);
}

float4 main(VS_OUTPUT input) : SV_Target
{
	float NdotV = saturate(input.TexCoord.x);
	float roughness = saturate(input.TexCoord.y);
	float2 brdf = IntegrateBRDF(NdotV, roughness);
	return float4(brdf, 0.0f, 1.0f);
}

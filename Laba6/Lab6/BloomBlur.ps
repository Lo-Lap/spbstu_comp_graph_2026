Texture2D srcTexture : register(t0);
SamplerState linearSampler : register(s0);

cbuffer BloomCB : register(b0)
{
	float4 Params0; 
	float4 Params1; 
};

struct PS_INPUT
{
	float4 Pos : SV_POSITION;
	float2 TexCoord : TEXCOORD;
};

float4 main(PS_INPUT input) : SV_Target
{
	float2 texel = float2(Params0.z, Params0.w) * Params1.xy;
	float3 c = 0.0f;
	c += srcTexture.Sample(linearSampler, input.TexCoord).rgb * 0.227027f;
	c += srcTexture.Sample(linearSampler, input.TexCoord + texel * 1.384615f).rgb * 0.316216f;
	c += srcTexture.Sample(linearSampler, input.TexCoord - texel * 1.384615f).rgb * 0.316216f;
	c += srcTexture.Sample(linearSampler, input.TexCoord + texel * 3.230769f).rgb * 0.070270f;
	c += srcTexture.Sample(linearSampler, input.TexCoord - texel * 3.230769f).rgb * 0.070270f;
	return float4(c, 1.0f);
}

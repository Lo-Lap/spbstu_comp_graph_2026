    }

    float3 diffuseColor = diffuseTexture.Sample(samplerState, input.TexCoord).rgb;
    float3 finalColor = lightColor;
    return float4(finalColor, 1.0f);
    */

    float3 P = input.WorldPos;
    float3 N = normalize(input.Normal);
    float3 lightColor = float3(0.0f, 0.0f, 0.0f);
    for(int i=0;i<3;i++)
    {
        float3 Lvec = lights[i].Position - P;
        float dist = length(Lvec);
        float3 L = Lvec / max(dist, 1e-4);
        float NdotL = saturate(dot(N, L));
        float x = dist / lights[i].Range;
        float falloff = 1.0 - smoothstep(0.9, 1.0, x);
        falloff = pow(falloff, 2.0);
        float3 contrib = lights[i].Color * lights[i].Intensity * NdotL * falloff;
        lightColor  += contrib;
    }

     return float4(lightColor, 1.0f);
 
}